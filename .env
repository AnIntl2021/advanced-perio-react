# ── EmailJS Credentials for Advanced Periodontics Chatbot ──
# 
# How to get these keys:
# 1. Sign up for a free account at https://www.emailjs.com/
# 2. Add an Email Service (connect the email address you want to send mail from).
# 3. Create your Email Templates (one for Admin notifications, one for Patient confirmation).
# 4. Copy the IDs and paste them below:

# Your EmailJS Service ID (e.g. service_xxxxxx)
VITE_EMAILJS_SERVICE_ID=service_i1oh76g

# Your EmailJS Template ID for Admin notifications (sent to admin@ and info@)
VITE_EMAILJS_TEMPLATE_ID=template_n6fp6g6

# Your EmailJS Template ID for Patient confirmations (sent to the patient)
VITE_EMAILJS_PATIENT_TEMPLATE_ID=template_n6fp6g6

# Your EmailJS Public Key (found under Account > API Keys in your EmailJS dashboard)
VITE_EMAILJS_PUBLIC_KEY=rnzmnUNtJDvLePNEG
